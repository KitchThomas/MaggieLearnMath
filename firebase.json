{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "auto-sync.js",
      "server.js",
      "package.json",
      "package-lock.json",
      "*.js",
      "repomix-output.xml"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
