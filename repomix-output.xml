      align-items: center;
      justify-content: center;
      font-size: 12px;
      flex-shrink: 0;
    }

    .topic-title .status.completed {
      background: #4CAF50;
      border-color: #4CAF50;
      color: white;
    }

    .topic-description {
      font-size: 0.85rem;
      color: #666;
      margin-left: 30px;
    }

    /* Modal */
    .modal-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0,0,0,0.7);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .modal-overlay.active {
      display: flex;
    }

    .modal {
      background: white;
      border-radius: 15px;
      max-width: 800px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
    }

    .modal-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 25px;
      position: sticky;
      top: 0;
    }

    .modal-header.grade6 {
      background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }

    .modal-header h2 {
      margin-bottom: 5px;
    }

    .modal-close {
      position: absolute;
      top: 15px;
      right: 15px;
      background: rgba(255,255,255,0.2);
      border: none;
      color: white;
      width: 35px;
      height: 35px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-close:hover {
      background: rgba(255,255,255,0.3);
    }

    .modal-content {
      padding: 25px;
    }

    .resource-section {
      margin-bottom: 25px;
    }

    .resource-section h3 {
      color: #333;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .resource-section h3 .icon {
      width: 30px;
      height: 30px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 14px;
    }

    .khan-icon { background: #14bf96; }
    .youtube-icon { background: #ff0000; }
    .practice-icon { background: #ff9800; }

    .resource-list {
      list-style: none;
    }

    .resource-item {
      padding: 12px 15px;
      background: #f8f9fa;
      border-radius: 10px;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: background 0.2s;
    }

    .resource-item:hover {
      background: #e9ecef;
    }

    .resource-item a {
      color: #667eea;
      text-decoration: none;
      font-weight: 500;
      flex: 1;
    }

    .resource-item a:hover {
      text-decoration: underline;
    }

    .resource-item .type-badge {
      font-size: 0.75rem;
      padding: 3px 8px;
      border-radius: 12px;
      background: #e0e0e0;
      color: #666;
      margin-left: 10px;
    }

    .resource-item .channel {
      font-size: 0.8rem;
      color: #888;
      margin-left: 10px;
    }

    .mark-complete-btn {
      width: 100%;
      padding: 15px;
      background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .mark-complete-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(76, 175, 80, 0.4);
    }

    .mark-complete-btn.completed {
      background: linear-gradient(135deg, #9e9e9e 0%, #757575 100%);
    }

    .no-resources {
      color: #999;
      font-style: italic;
      padding: 10px 0;
    }

    /* Responsive */
    @media (max-width: 768px) {
      header h1 {
        font-size: 1.8rem;
      }

      .units-grid {
        grid-template-columns: 1fr;
      }

      .grade-selector {
        flex-direction: column;
        align-items: center;
      }

      .grade-btn {
        width: 100%;
        max-width: 300px;
        justify-content: center;
      }
    }

    /* Stars decoration */
    .stars {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      pointer-events: none;
      overflow: hidden;
      z-index: -1;
    }

    .star {
      position: absolute;
      width: 4px;
      height: 4px;
      background: white;
      border-radius: 50%;
      opacity: 0.5;
      animation: twinkle 2s infinite;
    }

    @keyframes twinkle {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 0.8; }
    }

    /* Grade 6 theme */
    body.grade6-theme {
      background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }

    body.grade6-theme .grade-btn.active {
      color: #11998e;
    }

    body.grade6-theme .grade-badge {
      background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }

    body.grade6-theme .resource-item a {
      color: #11998e;
    }
  </style>
</head>
<body>
  <div class="stars" id="stars"></div>

  <div class="container">
    <header>
      <h1>🌟 Maggie's Math Learning 🌟</h1>
      <p id="headerSubtitle">Ontario Math Curriculum / 安大略省数学课程</p>
    </header>

    <!-- Grade Selector -->
    <div class="grade-selector">
      <button class="grade-btn active" onclick="switchGrade(5)" id="grade5Btn">
        <span class="grade-icon">5️⃣</span>
        <span>Grade 5 / 五年级</span>
      </button>
      <button class="grade-btn" onclick="switchGrade(6)" id="grade6Btn">
        <span class="grade-icon">6️⃣</span>
        <span>Grade 6 / 六年级</span>
      </button>
    </div>

    <div class="progress-section">
      <div class="progress-header">
        <h3>Learning Progress / 学习进度</h3>
        <span class="grade-badge" id="gradeBadge">Grade 5</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="progressFill"></div>
      </div>
      <p class="progress-text" id="progressText">0 / 0 topics completed</p>
    </div>

    <div class="units-grid" id="unitsContainer">
      <!-- Units will be loaded here -->
    </div>
  </div>

  <!-- Modal -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal">
      <div class="modal-header" id="modalHeader">
        <button class="modal-close" onclick="closeModal()">&times;</button>
        <h2 id="modalTitle">Topic Title</h2>
        <p id="modalDescription">Topic description</p>
      </div>
      <div class="modal-content" id="modalContent">
        <!-- Resources will be loaded here -->
      </div>
    </div>
  </div>

  <script>
    // State
    let curriculum = null;
    let currentGrade = 5;
    let completedTopics = {
      5: JSON.parse(localStorage.getItem('completedTopics_grade5') || '[]'),
      6: JSON.parse(localStorage.getItem('completedTopics_grade6') || '[]')
    };

    // Switch grade
    async function switchGrade(grade) {
      currentGrade = grade;

      // Update buttons
      document.getElementById('grade5Btn').classList.toggle('active', grade === 5);
      document.getElementById('grade6Btn').classList.toggle('active', grade === 6);

      // Update theme
      document.body.classList.toggle('grade6-theme', grade === 6);

      // Update badge
      document.getElementById('gradeBadge').textContent = `Grade ${grade}`;

      // Load curriculum
      await loadCurriculum();
    }

    // Load curriculum data
    async function loadCurriculum() {
      try {
        const fileName = currentGrade === 5 ? 'curriculum.json' : 'curriculum-grade6.json';
        const response = await fetch(fileName);
        curriculum = await response.json();
        renderUnits();
        updateProgress();
      } catch (error) {
        console.error('Failed to load curriculum:', error);
      }
    }

    // Render all units
    function renderUnits() {
      const container = document.getElementById('unitsContainer');
      container.innerHTML = '';

      curriculum.units.forEach((unit, unitIndex) => {
        // Calculate unit progress
        const completedInUnit = unit.topics.filter(t => isCompleted(t.id)).length;
        const totalInUnit = unit.topics.length;
        const unitPercent = totalInUnit > 0 ? (completedInUnit / totalInUnit) * 100 : 0;

        const unitCard = document.createElement('div');
        unitCard.className = 'unit-card';
        unitCard.innerHTML = `
          <div class="unit-header ${currentGrade === 6 ? 'grade6' : ''}" onclick="toggleUnit(${unitIndex})">
            <h2>${getUnitEmoji(unitIndex, currentGrade)} ${unit.title}</h2>
            <p>${unit.description}</p>
            <div class="unit-progress">
              <div class="unit-progress-bar">
                <div class="unit-progress-fill" style="width: ${unitPercent}%"></div>
              </div>
              <span>${completedInUnit}/${totalInUnit}</span>
            </div>
          </div>
          <div class="unit-topics" id="unit-${unitIndex}">
            ${unit.topics.map((topic, topicIndex) => `
              <div class="topic-item" onclick="openTopic('${unit.id}', '${topic.id}', event)">
                <div class="topic-title">
                  <span class="status ${isCompleted(topic.id) ? 'completed' : ''}">${isCompleted(topic.id) ? '✓' : ''}</span>
                  ${topic.title}
                </div>
                <div class="topic-description">${topic.description}</div>
              </div>
            `).join('')}
          </div>
        `;
        container.appendChild(unitCard);
      });
    }

    // Get emoji for unit based on grade
    function getUnitEmoji(index, grade) {
      const emojis5 = ['🔢', '🔵', '🍕', '➕', '📐', '📏', '📊', '💰', '🎯'];
      const emojis6 = ['🔢', '🍕', '⚖️', '💯', '🔵', '📝', '📐', '🗺️', '📊', '💰'];
      const emojis = grade === 5 ? emojis5 : emojis6;
      return emojis[index] || '📚';
    }

    // Toggle unit expansion
    function toggleUnit(unitIndex) {
      const unitCards = document.querySelectorAll('.unit-card');
      unitCards[unitIndex].classList.toggle('expanded');
    }

    // Check if topic is completed
    function isCompleted(topicId) {
      return completedTopics[currentGrade].includes(topicId);
    }

    // Open topic modal
    function openTopic(unitId, topicId, event) {
      event.stopPropagation();

      const unit = curriculum.units.find(u => u.id === unitId);
      const topic = unit.topics.find(t => t.id === topicId);

      document.getElementById('modalTitle').textContent = topic.title;
      document.getElementById('modalDescription').textContent = topic.description;
      document.getElementById('modalHeader').className = `modal-header ${currentGrade === 6 ? 'grade6' : ''}`;

      let content = '';

      // Khan Academy resources
      if (topic.khanAcademy && topic.khanAcademy.length > 0) {
        content += `
          <div class="resource-section">
            <h3><span class="icon khan-icon">K</span> Khan Academy</h3>
            <ul class="resource-list">
              ${topic.khanAcademy.map(resource => `
                <li class="resource-item">
                  <a href="${resource.url}" target="_blank">${resource.title}</a>
                  <span class="type-badge">${resource.type || 'video'}</span>
                </li>
              `).join('')}
            </ul>
          </div>
        `;
      }

      // YouTube resources
      if (topic.youtube && topic.youtube.length > 0) {
        content += `
          <div class="resource-section">
            <h3><span class="icon youtube-icon">▶</span> YouTube Videos</h3>
            <ul class="resource-list">
              ${topic.youtube.map(resource => `
                <li class="resource-item">
                  <a href="${resource.url}" target="_blank">${resource.title}</a>
                  <span class="channel">${resource.channel}</span>
                </li>
              `).join('')}
            </ul>
          </div>
        `;
      }

      // Practice resources
      if (topic.practice && topic.practice.length > 0) {
        content += `
          <div class="resource-section">
            <h3><span class="icon practice-icon">✎</span> Practice / 练习</h3>
            <ul class="resource-list">
              ${topic.practice.map(resource => `
                <li class="resource-item">
                  <a href="${resource.url}" target="_blank">${resource.title}</a>
                </li>
              `).join('')}
            </ul>
          </div>
        `;
      }

      // Mark complete button
      const isComplete = isCompleted(topicId);
      content += `
        <button class="mark-complete-btn ${isComplete ? 'completed' : ''}"
                onclick="toggleComplete('${topicId}')">
          ${isComplete ? '✓ Completed / 已完成' : 'Mark as Complete / 标记完成'}
        </button>
      `;

      document.getElementById('modalContent').innerHTML = content;
      document.getElementById('modalOverlay').classList.add('active');
    }

    // Close modal
    function closeModal() {
      document.getElementById('modalOverlay').classList.remove('active');
    }

    // Toggle topic completion
    function toggleComplete(topicId) {
      if (completedTopics[currentGrade].includes(topicId)) {
        completedTopics[currentGrade] = completedTopics[currentGrade].filter(id => id !== topicId);
      } else {
        completedTopics[currentGrade].push(topicId);
      }
      localStorage.setItem(`completedTopics_grade${currentGrade}`, JSON.stringify(completedTopics[currentGrade]));
      renderUnits();
      updateProgress();
      closeModal();
    }

    // Update progress bar
    function updateProgress() {
      let totalTopics = 0;
      curriculum.units.forEach(unit => {
        totalTopics += unit.topics.length;
      });

      const completed = completedTopics[currentGrade].length;
      const percentage = totalTopics > 0 ? (completed / totalTopics) * 100 : 0;

      document.getElementById('progressFill').style.width = percentage + '%';
      document.getElementById('progressText').textContent =
        `${completed} / ${totalTopics} topics completed (${Math.round(percentage)}%)`;
    }

    // Close modal on overlay click
    document.getElementById('modalOverlay').addEventListener('click', function(e) {
      if (e.target === this) {
        closeModal();
      }
    });

    // Create stars
    function createStars() {
      const starsContainer = document.getElementById('stars');
      for (let i = 0; i < 50; i++) {
        const star = document.createElement('div');
        star.className = 'star';
        star.style.left = Math.random() * 100 + '%';
        star.style.top = Math.random() * 100 + '%';
        star.style.animationDelay = Math.random() * 2 + 's';
        starsContainer.appendChild(star);
      }
    }

    // Initialize
    createStars();
    loadCurriculum();
  </script>
</body>
</html>
