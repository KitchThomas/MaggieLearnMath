    }

    .topic-item:last-child {
      border-bottom: none;
    }

    .topic-title {
      font-weight: 600;
      color: #333;
      margin-bottom: 5px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .topic-title .status {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      border: 2px solid #ddd;
